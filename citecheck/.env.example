# Copy this file to .env in the same directory and fill in real values.
# The .env file is gitignored.

# --- CourtListener API ---
# Get a free API key at https://www.courtlistener.com/help/api/rest/#authentication
# Rate limit: 5,000 requests/hour authenticated, 100/hour unauthenticated
CL_API_KEY=

# --- Hugging Face Hub (for dataset + model uploads, optional) ---
# Get a token at https://huggingface.co/settings/tokens
# Needed if you plan to push the CiteCheck benchmark to HF Hub
HF_TOKEN=

# --- Weights & Biases (experiment tracking, free tier) ---
# Get an API key at https://wandb.ai/authorize
WANDB_API_KEY=
WANDB_PROJECT=citecheck
WANDB_ENTITY=

# --- Hosted LLM teachers (optional, for synthetic trajectory generation) ---
# Used for LLM pre-labeling of eval-set candidates and synthetic ReAct trajectories
# OpenRouter aggregates many models behind one API
OPENROUTER_API_KEY=

# Or direct provider APIs (use whichever you prefer)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Local paths (override defaults if your data lives elsewhere) ---
# Default: ./data, ./models, ./indexes relative to citecheck/
CITECHECK_DATA_DIR=
CITECHECK_MODELS_DIR=
CITECHECK_INDEXES_DIR=
